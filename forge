-

---

## 评审记录

| 日期 | 评审人 | 结论 | 备注 |
|------|-------|------|------|
| | | | |
EOF

  echo -e "${GREEN}✓${NC} Created: $filename"
  echo "  Number: EP-${number}"
  echo "  Status: draft"
  echo "  Next: edit the file to fill in details"
}

_ep_list() {
  if [ ! -d "evolution" ] || [ -z "$(find evolution -name 'EP-[0-9]*.md' 2>/dev/null)" ]; then
    echo "No Evolution Proposals found."
    echo "Create one with: forge ep create <title>"
    return 0
  fi

  echo -e "${BLUE}Evolution Proposals${NC}"
  echo "────────────────────────────────────"
  printf "  %-8s %-14s %s\n" "Number" "Status" "Title"
  echo "  ──────── ────────────── ──────────────────────────────"

  for f in evolution/EP-[0-9]*.md; do
    [ -f "$f" ] || continue
    # Skip template file
    echo "$f" | grep -q "template" && continue
    local basename_f
    basename_f=$(basename "$f" .md)
    local number
    number=$(echo "$basename_f" | grep -o 'EP-[0-9]*' | head -1)
    local status
    status=$(grep "^> 状态:" "$f" 2>/dev/null | sed 's/^> 状态: *//')
    [ -z "$status" ] && status="unknown"
    local title
    title=$(head -1 "$f" | sed 's/^# EP-[0-9]*: *//')

    local color="$NC"
    case "$status" in
      draft)       color="$YELLOW" ;;
      reviewing)   color="$BLUE" ;;
      accepted)    color="$GREEN" ;;
      rejected)    color="$RED" ;;
      implemented) color="$GREEN" ;;
    esac

    printf "  %-8s ${color}%-14s${NC} %s\n" "$number" "$status" "$title"
  done
}

_ep_status() {
  local number="${1:-}"
  local new_status="${2:-}"

  if [ -z "$number" ] || [ -z "$new_status" ]; then
    echo "Usage: forge ep status <number> <status>"
    echo "  status: draft | reviewing | accepted | rejected | implemented"
    return 1
  fi

  local valid_statuses="draft reviewing accepted rejected implemented"
  if ! echo "$valid_statuses" | grep -qw "$new_status"; then
    echo -e "${RED}Error: invalid status '$new_status'${NC}"
    echo "  Valid: $valid_statuses"
    return 1
  fi

  # Pad number to 3 digits
  local padded
  padded=$(printf "%03d" "$number" 2>/dev/null || echo "$number")

  local target_file
  target_file=$(find evolution -name "EP-${padded}-*.md" 2>/dev/null | head -1)

  if [ -z "$target_file" ] || [ ! -f "$target_file" ]; then
    echo -e "${RED}Error: EP-${padded} not found${NC}"
    return 1
  fi

  # Update status in file
  if [ "$(uname)" = "Darwin" ]; then
    sed -i '' "s/^> 状态: .*/> 状态: ${new_status}/" "$target_file"
  else
    sed -i "s/^> 状态: .*/> 状态: ${new_status}/" "$target_file"
  fi

  echo -e "${GREEN}✓${NC} EP-${padded} status updated to: ${new_status}"
}

forge_uninstall() {
  echo -e "${YELLOW}This will remove ForgeTeam from your system:${NC}"
  echo "  • $FORGE_HOME (skills, config, upstream cache)"
  echo "  • /usr/local/bin/forge (symlink)"
  echo ""
  read -p "Are you sure? [y/N] " confirm
  [ "$confirm" != "y" ] && { echo "Cancelled."; exit 0; }

  if [ -L "/usr/local/bin/forge" ]; then
    if [ -w "/usr/local/bin" ]; then
      rm -f /usr/local/bin/forge
    else
      sudo rm -f /usr/local/bin/forge
    fi
    echo -e "  ${GREEN}✓${NC} Removed /usr/local/bin/forge"
  fi

  if [ -d "$FORGE_HOME" ]; then
    rm -rf "$FORGE_HOME"
    echo -e "  ${GREEN}✓${NC} Removed $FORGE_HOME"
  fi

  echo ""
  echo -e "${GREEN}ForgeTeam uninstalled.${NC}"
  echo "Note: Project-local .forgeteam/ directories are not removed."
}

forge_skill() {
  local skill_name=$1
  echo -e "${BLUE}ForgeTeam: ${skill_name}${NC}"
  echo ""
  echo "This skill is designed to be executed by AI coding assistants."
  echo ""
  echo "Usage options:"
  echo "  • In Claude Code: use /forge-${skill_name}"
  echo "  • In Cursor: AI will auto-detect based on context"
  echo "  • Manual: read skills/${skill_name}/SKILL.md for instructions"
  echo ""
  echo "Skill file: \$HOME/.forgeteam/skills/${skill_name}/SKILL.md"
}

case "${1:-}" in
  init)       shift; forge_init "$@" ;;
  onboard)    shift; forge_onboard "$@" ;;
  generate)   shift; forge_generate "$@" ;;
  sync)       shift; forge_sync "$@" ;;
  status)     shift; forge_status "$@" ;;
  config)     shift; forge_config "$@" ;;
  uninstall)  shift; forge_uninstall "$@" ;;
  version)    echo "ForgeTeam v${FORGE_VERSION}" ;;
  verify)     shift; forge_verify "$@" ;;
  doctor)     shift; forge_doctor "$@" ;;
  add)        shift; forge_add "$@" ;;
  remove)     shift; forge_remove "$@" ;;
  ep)         shift; forge_ep "$@" ;;
  evolve)     shift; forge_evolve_cli "$@" ;;
  analytics)  shift; forge_analytics "$@" ;;
  checkpoint) shift; forge_checkpoint "$@" ;;
  worktree)   shift; forge_worktree "$@" ;;
  bundle)     shift; forge_bundle "$@" ;;
  state)      shift; forge_state "$@" ;;
  index)      shift; forge_index "$@" ;;
  workspace)  shift; forge_workspace "$@" ;;
  spec)       shift; forge_spec "$@" ;;
  tdd)        shift; forge_tdd "$@" ;;
  memory)     shift; forge_memory_cli "$@" ;;
  propose|html-prototype|plan|execute|review|ship|debug)
              forge_skill "$@" ;;
  -h|--help)  usage ;;
  "")         usage ;;
  *)          usage; exit 1 ;;
esac
