#!/bin/bash
# ForgeTeam CLI — 主入口
# 用法: forge <command> [options]

set -euo pipefail

FORGE_VERSION="1.1.0"
FORGE_HOME="${FORGE_HOME:-$HOME/.forgeteam}"
FORGE_SKILLS="$FORGE_HOME/skills"

# Color support (disabled when not a terminal)
if [ -t 1 ]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  BLUE='\033[0;34m'
  NC='\033[0m'
else
  RED='' GREEN='' YELLOW='' BLUE='' NC=''
fi

# Sanitize a string for safe YAML/markdown interpolation
sanitize_value() {
  local val="$1"
  # Remove characters that could break YAML or inject content
  val="${val//\"/}"
  val="${val//\`/}"
  val="${val//\$/}"
  val="${val//\\/}"
  # Limit length
  val="${val:0:128}"
  echo "$val"
}

# Portable date (macOS + Linux compatible)
portable_date() {
  date '+%Y-%m-%dT%H:%M:%S%z' 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S'
}

usage() {
  cat <<EOF
ForgeTeam v${FORGE_VERSION} — One person, full team delivery.

Usage: forge <command> [options]

Commands:
  init          Initialize ForgeTeam in current project
  onboard       Scan project and generate project map
  generate      Generate platform-specific files
  sync          Sync upstream skill updates
  status        Show current task status
  config        View/edit configuration
  verify        Run verification gates (build → test → run → safety)
  doctor        Check configuration health and diagnose issues
  add           Install an extension (git url, local path, or registry name)
  remove        Uninstall an extension
  ep            Manage Evolution Proposals (create/list/status)
  uninstall     Remove ForgeTeam from system
  version       Show version

Skill Commands (also available as slash commands in AI tools):
  propose         Start a new proposal (full route)
  html-prototype  Generate HTML prototype for visual confirmation
  plan            Create task plan
  execute         Execute tasks
  review          Run code review
  verify          Run verification gates (safety + phase gate + 4-gate pipeline)
  ship            Commit and archive
  debug           Debug verification failures
  memory          Save progress and extract learnings
  evolve          Evaluate ecosystem changes
  analytics       Record local, privacy-minimized workflow events
  checkpoint      Save a recoverable WIP checkpoint
  worktree        Manage optional isolated Git worktrees
  bundle          Validate a portable extension bundle
  state           Show/transition workflow state or record plan approval
  index           Rebuild the local task index
  workspace       Register/list explicit local repository roots
  spec            Archive a spec and preserve its delta history
  tdd             Check a task plan's test-first contract
  memory          Record or prune evidence-backed local memory

Options:
  -h, --help    Show this help

EOF
}

# ─── Shared Detection Logic ───

detect_project() {
  # Outputs variables: lang, framework, type, build_cmd, test_cmd, start_cmd, dev_cmd, pkg_manager, project_name, project_version
  lang="unknown"
  framework=""
  type="web-app"
  build_cmd=""
  test_cmd=""
  start_cmd=""
  dev_cmd=""
  pkg_manager="unknown"
  project_name=$(sanitize_value "$(basename "$(pwd)")")
  project_version=""

  if [ -f "package.json" ]; then
    lang="typescript"
    build_cmd="npm run build"
    test_cmd="npm test"
    start_cmd="npm start"
    dev_cmd="npm run dev"

    # Detect package manager
    if [ -f "pnpm-lock.yaml" ]; then pkg_manager="pnpm"
    elif [ -f "yarn.lock" ]; then pkg_manager="yarn"
    elif [ -f "package-lock.json" ]; then pkg_manager="npm"
    else pkg_manager="npm"
    fi

    # Extract name/version safely
    local raw_name raw_version
    raw_name=$(grep '"name"' package.json 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/' || echo "")
    raw_version=$(grep '"version"' package.json 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/' || echo "")
    [ -n "$raw_name" ] && project_name=$(sanitize_value "$raw_name")
    [ -n "$raw_version" ] && project_version=$(sanitize_value "$raw_version")

    # Detect framework from dependencies
    if grep -q '"next"' package.json 2>/dev/null; then framework="next"
    elif grep -q '"react"' package.json 2>/dev/null; then framework="react"
    elif grep -q '"vue"' package.json 2>/dev/null; then framework="vue"
    elif grep -q '"express"' package.json 2>/dev/null; then framework="express"
    fi

    # Library detection
    if grep -q '"main"' package.json 2>/dev/null && [ "$framework" != "next" ]; then
      type="library"
    fi
  elif [ -f "pom.xml" ]; then
    lang="java"
    framework="spring"
    build_cmd="mvn compile"
    test_cmd="mvn test"
    start_cmd="mvn spring-boot:run"
  elif [ -f "build.gradle" ] || [ -f "build.gradle.kts" ]; then
    lang="java"
    framework="spring"
    build_cmd="./gradlew build"
    test_cmd="./gradlew test"
    start_cmd="./gradlew bootRun"
  elif [ -f "go.mod" ]; then
    lang="go"
    build_cmd="go build ./..."
    test_cmd="go test ./..."
    start_cmd="go run ."
  elif [ -f "Cargo.toml" ]; then
    lang="rust"
    build_cmd="cargo build"
    test_cmd="cargo test"
    start_cmd="cargo run"
  elif [ -f "pyproject.toml" ] || [ -f "requirements.txt" ]; then
    lang="python"
    test_cmd="pytest"
    if [ -f "manage.py" ]; then
      framework="django"
      start_cmd="python manage.py runserver"
    elif [ -f "requirements.txt" ] && grep -qi "fastapi" requirements.txt 2>/dev/null; then
      framework="fastapi"
      start_cmd="uvicorn main:app"
    elif [ -f "pyproject.toml" ] && grep -q '"fastapi"' pyproject.toml 2>/dev/null; then
      framework="fastapi"
      start_cmd="uvicorn main:app"
    fi
  fi
}

# ─── Commands ───

forge_init() {
  local project_dir
  project_dir=$(pwd)

  echo -e "${BLUE}ForgeTeam Init${NC}"
  echo "Project: $project_dir"
  echo ""

  if [ -d ".forgeteam" ]; then
    echo -e "${YELLOW}Warning: .forgeteam already exists${NC}"
    read -p "Reinitialize? [y/N] " confirm
    [ "$confirm" != "y" ] && exit 0
  fi

  echo "Creating .forgeteam/..."
  mkdir -p .forgeteam/memory
  mkdir -p .forgeteam/extensions/skills
  mkdir -p .forgeteam/extensions/templates
  mkdir -p .forgeteam/analytics
  mkdir -p .forgeteam/workspaces
  mkdir -p specs/active
  mkdir -p specs/archived

  echo "Detecting project..."
  detect_project

  echo "Generating config.yaml..."
  cat > .forgeteam/config.yaml <<YAML
version: "1.0"

project:
  name: "${project_name}"
  type: "${type}"
  language: "${lang}"
  framework: "${framework}"
  description: ""

routing:
  micro_threshold: 50
  standard_threshold: 500
  default_route: "auto"
  force_full_on:
    - "database migration"
    - "new api endpoint"
    - "architecture change"

verification:
  build_gate: true
  test_gate: true
  run_gate: $([ "$type" = "library" ] && echo "false" || echo "true")
  safety_gate: true
  coverage_threshold: 80
  circuit_breaker_limit: 3
  test_gate_mode: "warn"

commands:
  build: "${build_cmd}"
  test: "${test_cmd}"
  start: "${start_cmd}"
  dev: "${dev_cmd}"
  lint: ""
  format: ""
  health_url: ""

memory:
  auto_update: true
  track_decisions: true
  track_issues: true
  max_known_issues: 50
  max_decisions: 100

analytics:
  enabled: true
  retention_days: 90

workspaces:
  enabled: false
  roots: []

safety:
  level: "standard"
  allow_force_push: false
  secret_scan: true
  protected_branches:
    - "main"
    - "master"

review:
  strict_mode: false
  security_check: true
  performance_check: true
  style_check: true
  max_review_rounds: 3

quality_gates:
  strict: false
  allow_skip: true
  skip_log: true

extensions:
  skills: []
  mcp_servers: []
  templates: []

adapters:
  target: "claude"
  auto_generate: true

upstream:
  repo: "https://github.com/chengxuniucode/ForgeTeam.git"
  branch: "main"
  auto_check: false
  check_interval: "weekly"
  preserve_local: true
YAML

  # Update .gitignore
  if [ -f ".gitignore" ]; then
    if ! grep -Fq ".forgeteam/safety.log" .gitignore 2>/dev/null; then
      echo "" >> .gitignore
      echo "# ForgeTeam" >> .gitignore
      echo ".forgeteam/safety.log" >> .gitignore
      echo ".forgeteam/gates.log" >> .gitignore
    fi
  else
    cat > .gitignore <<'GITIGNORE'
# ForgeTeam
.forgeteam/safety.log
.forgeteam/gates.log
GITIGNORE
  fi

  # Complete the local memory contract without overwriting user-authored files.
  for memory_file in decisions known-issues preferences state; do
    if [ ! -f ".forgeteam/memory/${memory_file}.md" ] && [ -f "$FORGE_HOME/templates/memory/${memory_file}.md" ]; then
      cp "$FORGE_HOME/templates/memory/${memory_file}.md" ".forgeteam/memory/${memory_file}.md"
    fi
  done
  : > .forgeteam/analytics/events.jsonl

  echo ""
  echo "Running onboard..."
  forge_onboard

  echo ""
  echo "Generating platform files..."
  forge_generate --target "claude"

  echo ""
  echo -e "${GREEN}✓ ForgeTeam initialized successfully!${NC}"
  echo ""
  echo "Next steps:"
  echo "  1. Review .forgeteam/config.yaml"
  echo "  2. Review .forgeteam/memory/project-map.md"
  echo "  3. Start working: describe what you want to build"
}

_analytics_event() {
  local stage="$1" event="$2" outcome="${3:-unknown}" reason="${4:-}"
  [ -d ".forgeteam" ] || { echo "Not initialized. Run: forge init"; return 1; }
  mkdir -p .forgeteam/analytics
  local task_id route safe_reason
  task_id=$(grep '^\- Task ID:' .forgeteam/memory/state.md 2>/dev/null | head -1 | sed 's/.*: *//' || true)
  route=$(grep '^\- 路由:' .forgeteam/memory/state.md 2>/dev/null | head -1 | sed 's/.*: *//' || true)
  safe_reason=$(sanitize_value "$reason")
  printf '{"timestamp":"%s","task_id":"%s","route":"%s","stage":"%s","event":"%s","outcome":"%s","reason":"%s"}\n' "$(portable_date)" "${task_id:-anonymous}" "${route:-unknown}" "$stage" "$event" "$outcome" "$safe_reason" >> .forgeteam/analytics/events.jsonl
}

forge_analytics() {
  [ "${1:-}" = "event" ] || { echo "Usage: forge analytics event <stage> <event> [outcome] [reason]"; return 1; }
  shift
  [ $# -ge 2 ] || { echo "Usage: forge analytics event <stage> <event> [outcome] [reason]"; return 1; }
  _analytics_event "$1" "$2" "${3:-unknown}" "${4:-}"
  echo "✓ Local analytics event recorded"
}

forge_checkpoint() {
  local description="$*"
  [ -n "$description" ] || { echo "Usage: forge checkpoint <description>"; return 1; }
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "Error: checkpoint requires a Git worktree"; return 1; }
  git diff --quiet && git diff --cached --quiet && { echo "Nothing to checkpoint"; return 0; }
  git add -A
  git commit -m "wip: checkpoint - $(sanitize_value "$description")"
  _analytics_event memory checkpoint pass "$description" || true
}

forge_worktree() {
  local subcmd="${1:-list}" name="${2:-}"
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "Error: worktree requires a Git repository"; return 1; }
  case "$subcmd" in
    list) git worktree list ;;
    create)
      [[ "$name" =~ ^[a-zA-Z0-9._-]+$ ]] || { echo "Error: invalid worktree name"; return 1; }
      mkdir -p .forgeteam/workspaces
      git worktree add ".forgeteam/workspaces/$name" -b "forge/$name"
      _analytics_event workspace create pass "$name" || true ;;
    remove)
      [[ "$name" =~ ^[a-zA-Z0-9._-]+$ ]] || { echo "Error: invalid worktree name"; return 1; }
      [ -d ".forgeteam/workspaces/$name" ] || { echo "Error: worktree not found"; return 1; }
      git worktree remove ".forgeteam/workspaces/$name"
      _analytics_event workspace remove pass "$name" || true ;;
    *) echo "Usage: forge worktree <list|create|remove> [name]"; return 1 ;;
  esac
}

forge_bundle() {
  local action="${1:-}" target="${2:-}"
  if [ "$action" = export ]; then
    [ -d "$target" ] || { echo "Error: extension directory not found"; return 1; }
    local output="${3:-$(basename "$target").tar.gz}"
    tar -czf "$output" -C "$(dirname "$target")" "$(basename "$target")"
    echo "✓ Bundle exported: $output"
    return 0
  fi
  [ "$action" = "validate" ] || { echo "Usage: forge bundle <validate|export> <extension-dir> [output]"; return 1; }
  [ -f "$target/SKILL.md" ] || { echo "Error: SKILL.md not found"; return 1; }
  head -1 "$target/SKILL.md" | grep -q '^---$' || { echo "Error: invalid SKILL.md frontmatter"; return 1; }
  grep -q '^name:' "$target/SKILL.md" || { echo "Error: missing skill name"; return 1; }
  if [ -f "$target/manifest.yaml" ]; then
    grep -q '^name:' "$target/manifest.yaml" || { echo "Error: manifest missing name"; return 1; }
    grep -q '^platforms:' "$target/manifest.yaml" || { echo "Error: manifest missing platforms"; return 1; }
  fi
  echo "✓ Portable extension bundle is valid"
}

forge_state() {
  local subcmd="${1:-show}" value="${2:-}"
  [ -f .forgeteam/memory/state.md ] || { echo "Not initialized. Run: forge init"; return 1; }
  case "$subcmd" in
    show) cat .forgeteam/memory/state.md ;;
    transition)
      case "$value" in planned|running|blocked|verifying|done|aborted) ;; *) echo "Usage: forge state transition <planned|running|blocked|verifying|done|aborted>"; return 1;; esac
      sed -i.bak "s/^- 状态:.*/- 状态: $value/" .forgeteam/memory/state.md && rm -f .forgeteam/memory/state.md.bak
      _analytics_event state transition pass "$value" || true ;;
    approve)
      printf '\n- 计划批准: %s\n' "$(portable_date)" >> .forgeteam/memory/state.md
      _analytics_event plan approved pass "human approval" || true ;;
    *) echo "Usage: forge state <show|transition|approve>"; return 1;;
  esac
}

forge_index() {
  [ "${1:-rebuild}" = "rebuild" ] || { echo "Usage: forge index rebuild"; return 1; }
  mkdir -p .forgeteam/memory
  {
    echo '# Task Index'
    echo
    for root in specs/active specs/archived; do
      [ -d "$root" ] || continue
      find "$root" -mindepth 1 -maxdepth 1 -type d 2>/dev/null || true
    done | while read -r d; do
      printf -- '- %s | %s | %s\n' "$(basename "$d")" "$(basename "$(dirname "$d")")" "$(find "$d" -maxdepth 1 -type f -name tasks.md -exec grep -c '^\- \[x\]' {} \; 2>/dev/null || echo 0)"
    done
  } > .forgeteam/memory/index.md
  echo "✓ Task index rebuilt"
}

forge_workspace() {
  local subcmd="${1:-list}" path="${2:-}"
  mkdir -p .forgeteam/workspaces
  case "$subcmd" in
    add) [ -d "$path" ] || { echo "Error: directory not found"; return 1; }; printf '%s\n' "$(cd "$path" && pwd)" >> .forgeteam/workspaces/roots.txt; sort -u .forgeteam/workspaces/roots.txt -o .forgeteam/workspaces/roots.txt ;;
    list) cat .forgeteam/workspaces/roots.txt 2>/dev/null || true ;;
    *) echo "Usage: forge workspace <add|list> [path]"; return 1;;
  esac
}

forge_memory_cli() {
  local subcmd="${1:-record}" type="${2:-}" text="${3:-}"
  case "$subcmd" in
    record)
      case "$type" in decision|issue|preference) ;; *) echo "Usage: forge memory record <decision|issue|preference> <text>"; return 1;; esac
      [ -n "$text" ] || { echo "Error: text required"; return 1; }
      printf '\n- [%s] evidence: manual; confidence: medium; reviewed: %s\n' "$text" "$(date '+%Y-%m-%d')" >> ".forgeteam/memory/${type}s.md"
      ;;
    prune) find .forgeteam/memory -name '*.md' -type f -mtime +180 -print ;;
    *) echo "Usage: forge memory <record|prune> ..."; return 1;;
  esac
}

forge_spec() {
  local subcmd="${1:-}" slug="${2:-}"
  [ "$subcmd" = archive ] && [ -n "$slug" ] || { echo "Usage: forge spec archive <slug>"; return 1; }
  local source="specs/active/$slug" target="specs/archived/$slug"
  [ -d "$source" ] || { echo "Error: active spec not found"; return 1; }
  mkdir -p specs/current specs/archived
  if [ -f "$source/delta.md" ]; then cat "$source/delta.md" >> specs/current/CHANGELOG.md; fi
  mv "$source" "$target"
  forge_index rebuild
  echo "✓ Spec archived with delta history"
}

forge_tdd() {
  local task_file="${2:-}"
  [ "${1:-}" = check ] && [ -n "$task_file" ] || { echo "Usage: forge tdd check <tasks.md>"; return 1; }
  grep -qiE 'test.first|测试先行|失败测试' "$task_file" || { echo "FAIL: task plan lacks a test-first contract or an explicit exemption"; return 1; }
  echo "✓ Test-first contract recorded"
}

forge_onboard() {
  echo -e "${BLUE}Onboard: Scanning project...${NC}"

  detect_project

  # Framework display name
  local framework_display="$framework"
  case "$framework" in
    next) framework_display="Next.js" ;;
    react) framework_display="React" ;;
    vue) framework_display="Vue" ;;
    express) framework_display="Express" ;;
    spring) framework_display="Spring Boot" ;;
    django) framework_display="Django" ;;
    fastapi) framework_display="FastAPI" ;;
  esac

  local tree_output
  tree_output=$(find . -maxdepth 2 -type d \
    ! -path "*/node_modules*" \
    ! -path "*/.git*" \
    ! -path "*/dist*" \
    ! -path "*/build*" \
    ! -path "*/target*" \
    ! -path "*/__pycache__*" \
    ! -path "*/vendor*" \
    ! -path "*/.forgeteam*" \
    2>/dev/null | sort | head -40)

  # Detect entry point
  local entry="unknown"
  if [ -f "src/index.ts" ]; then entry="src/index.ts"
  elif [ -f "src/main.ts" ]; then entry="src/main.ts"
  elif [ -f "src/index.js" ]; then entry="src/index.js"
  elif [ -f "index.js" ]; then entry="index.js"
  elif [ -d "src/main/java" ]; then entry="src/main/java/"
  elif [ -f "main.go" ]; then entry="main.go"
  elif [ -f "src/main.rs" ]; then entry="src/main.rs"
  elif [ -f "manage.py" ]; then entry="manage.py"
  fi

  # Detect test directory
  local test_dir="none detected"
  if [ -d "tests" ]; then test_dir="tests/"
  elif [ -d "test" ]; then test_dir="test/"
  elif [ -d "__tests__" ]; then test_dir="__tests__/"
  elif [ -d "src/test" ]; then test_dir="src/test/"
  fi

  # Detect config files
  local config_files
  config_files=$(find . -maxdepth 1 -name "*.config.*" -o -name ".env.example" -o -name "tsconfig.json" -o -name "application.yml" -o -name "application.properties" 2>/dev/null | sed 's|^\./||' | tr '\n' ', ' | sed 's/,$//')
  [ -z "$config_files" ] && config_files="none detected"

  mkdir -p .forgeteam/memory

  cat > .forgeteam/memory/project-map.md <<EOF
# Project Map

## 基础信息
- 名称: ${project_name}
- 类型: ${type}
- 语言: ${lang}
- 框架: ${framework_display}
- 版本: ${project_version}

## 构建与运行
- 包管理: ${pkg_manager}
- 构建命令: ${build_cmd}
- 测试命令: ${test_cmd}
- 启动命令: ${start_cmd}
- 开发命令: ${dev_cmd}

## 目录结构
${tree_output}

## 关键文件
- 入口: ${entry}
- 配置: ${config_files}
- 测试: ${test_dir}

## 备注
- 生成时间: $(portable_date)
- 最后更新: $(portable_date)
EOF

  echo -e "  ${GREEN}✓${NC} project-map.md generated"
}

forge_generate() {
  local target="claude"

  while [[ $# -gt 0 ]]; do
    case $1 in
      --target) target="$2"; shift 2 ;;
      *) echo "Unknown option: $1. Valid targets: claude, cursor, codex, opencode"; exit 1 ;;
    esac
  done

  echo -e "${BLUE}Generating for: ${target}${NC}"

  local adapter_file="$FORGE_HOME/adapters/${target}.sh"
  if [ ! -f "$adapter_file" ]; then
    echo -e "${RED}Error: Adapter not found: ${adapter_file}${NC}"
    echo "Valid targets: claude, cursor, codex, opencode"
    exit 1
  fi

  source "$adapter_file"
  "generate_${target}"

  echo -e "${GREEN}✓ Generated ${target} configuration${NC}"
}


forge_sync() {
  local upstream_repo="https://github.com/chengxuniucode/ForgeTeam.git"

  echo -e "${BLUE}Syncing from upstream...${NC}"

  if [ -d "$FORGE_HOME/.upstream" ]; then
    echo "Pulling latest..."
    if ! git -C "$FORGE_HOME/.upstream" pull --ff-only 2>/dev/null; then
      echo -e "${YELLOW}Warning: Fast-forward pull failed. Recloning...${NC}"
      rm -rf "$FORGE_HOME/.upstream"
      git clone --depth 1 "$upstream_repo" "$FORGE_HOME/.upstream"
    fi
  else
    echo "Cloning upstream..."
    git clone --depth 1 "$upstream_repo" "$FORGE_HOME/.upstream"
  fi

  local remote_version local_version
  remote_version=$(cat "$FORGE_HOME/.upstream/skills/version.txt" 2>/dev/null || echo "0.0.0")
  local_version=$(cat "$FORGE_SKILLS/version.txt" 2>/dev/null || echo "0.0.0")

  echo "Local: v${local_version}"
  echo "Remote: v${remote_version}"

  if [ "$local_version" = "$remote_version" ]; then
    echo -e "${GREEN}Already up to date.${NC}"
    return 0
  fi

  echo "Updating skills..."
  for skill_dir in "$FORGE_HOME/.upstream/skills"/*/; do
    [ -d "$skill_dir" ] || continue

    local skill_name
    skill_name=$(basename "$skill_dir")
    local target_dir="$FORGE_SKILLS/$skill_name"

    if [ -d "$target_dir" ] && [ -f "$target_dir/.local-modified" ]; then
      echo -e "  ${YELLOW}SKIP${NC} $skill_name (locally modified)"
      continue
    fi

    echo -e "  ${GREEN}UPDATE${NC} $skill_name"
    # Atomic copy: write to temp then move
    local tmp_dir="${target_dir}.tmp.$$"
    cp -r "$skill_dir" "$tmp_dir"
    rm -rf "$target_dir"
    mv "$tmp_dir" "$target_dir"
  done

  echo "$remote_version" > "$FORGE_SKILLS/version.txt"

  if [ -f ".forgeteam/config.yaml" ]; then
    echo ""
    echo "Regenerating platform files..."
    local target
    target=$(grep "target:" .forgeteam/config.yaml | awk '{print $2}' | tr -d '"')
    forge_generate --target "${target:-claude}"
  fi

  echo ""
  echo -e "${GREEN}✓ Synced to v${remote_version}${NC}"
}

forge_status() {
  echo -e "${BLUE}ForgeTeam Status${NC}"
  echo "────────────────────────"

  if [ -f ".forgeteam/config.yaml" ]; then
    local name lang
    name=$(grep "name:" .forgeteam/config.yaml | head -1 | awk '{print $2}' | tr -d '"')
    lang=$(grep "language:" .forgeteam/config.yaml | awk '{print $2}' | tr -d '"')
    echo "Project: $name ($lang)"
  else
    echo -e "${YELLOW}Not initialized. Run: forge init${NC}"
    return 1
  fi

  echo ""

  if [ -f ".forgeteam/memory/state.md" ]; then
    echo "Current State:"
    grep "^- " .forgeteam/memory/state.md 2>/dev/null | head -6 | while read -r line; do
      echo "  $line"
    done
  else
    echo "State: idle (no active task)"
  fi

  echo ""

  if [ -d "specs/active" ]; then
    local active_count
    active_count=$(find specs/active -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
    echo "Active Specs: $active_count"
    find specs/active -mindepth 1 -maxdepth 1 -type d 2>/dev/null | while read -r spec_dir; do
      local spec tasks_total tasks_done
      spec=$(basename "$spec_dir")
      tasks_total=$(grep -c "^\- \[" "$spec_dir/tasks.md" 2>/dev/null || echo "0")
      tasks_done=$(grep -c "^\- \[x\]" "$spec_dir/tasks.md" 2>/dev/null || echo "0")
      echo "  • $spec ($tasks_done/$tasks_total)"
    done
  fi

  echo ""

  if [ -d "specs/archived" ]; then
    local archived_count
    archived_count=$(find specs/archived -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
    echo "Archived Specs: $archived_count"
  fi
}

forge_config() {
  if [ -f ".forgeteam/config.yaml" ]; then
    cat .forgeteam/config.yaml
  else
    echo -e "${YELLOW}Not initialized. Run: forge init${NC}"
    exit 1
  fi
}

_config_get() {
  local key="$1"
  grep "^  ${key}:" .forgeteam/config.yaml 2>/dev/null | head -1 | sed 's/^[^:]*: *//' | tr -d '"'
}

forge_verify() {
  if [ ! -f ".forgeteam/config.yaml" ]; then
    echo -e "${YELLOW}Not initialized. Run: forge init${NC}"
    exit 1
  fi

  echo -e "${BLUE}ForgeTeam Verify${NC}"
  echo "════════════════════════════════"

  local build_cmd test_cmd start_cmd project_type
  local build_gate test_gate run_gate safety_gate
  local gates_passed=0 gates_failed=0 gates_skipped=0

  build_cmd=$(_config_get "build")
  test_cmd=$(_config_get "test")
  start_cmd=$(_config_get "start")
  project_type=$(_config_get "type")
  build_gate=$(_config_get "build_gate")
  test_gate=$(_config_get "test_gate")
  run_gate=$(_config_get "run_gate")
  safety_gate=$(_config_get "safety_gate")

  # ─── Gate 1: Build ───
  echo ""
  echo "Gate 1: Build"
  if [ "$build_gate" = "false" ]; then
    echo -e "  ${YELLOW}SKIP${NC} (disabled in config)"
    ((gates_skipped++))
  elif [ -z "$build_cmd" ]; then
    echo -e "  ${YELLOW}SKIP${NC} (no build command configured)"
    ((gates_skipped++))
  else
    echo "  Running: $build_cmd"
    if eval "$build_cmd" > /dev/null 2>&1; then
      echo -e "  ${GREEN}PASS${NC}"
      ((gates_passed++))
    else
      echo -e "  ${RED}FAIL${NC}"
      ((gates_failed++))
    fi
  fi

  # ─── Gate 2: Test ───
  echo ""
  echo "Gate 2: Test"
  if [ "$test_gate" = "false" ]; then
    echo -e "  ${YELLOW}SKIP${NC} (disabled in config)"
    ((gates_skipped++))
  elif [ -z "$test_cmd" ]; then
    echo -e "  ${YELLOW}SKIP${NC} (no test command configured)"
    ((gates_skipped++))
  else
    echo "  Running: $test_cmd"
    if eval "$test_cmd" > /dev/null 2>&1; then
      echo -e "  ${GREEN}PASS${NC}"
      ((gates_passed++))
    else
      echo -e "  ${RED}FAIL${NC}"
      ((gates_failed++))
    fi
  fi

  # ─── Gate 3: Run ───
  echo ""
  echo "Gate 3: Run"
  if [ "$run_gate" = "false" ]; then
    echo -e "  ${YELLOW}SKIP${NC} (disabled in config)"
    ((gates_skipped++))
  elif [ "$project_type" = "library" ]; then
    echo -e "  ${YELLOW}SKIP${NC} (library project)"
    ((gates_skipped++))
  elif [ -z "$start_cmd" ]; then
    echo -e "  ${YELLOW}SKIP${NC} (no start command configured)"
    ((gates_skipped++))
  else
    echo "  Running: $start_cmd"
    eval "$start_cmd" > /dev/null 2>&1 &
    local pid=$!
    sleep 5
    if kill -0 "$pid" 2>/dev/null; then
      echo -e "  ${GREEN}PASS${NC} (process alive after 5s)"
      ((gates_passed++))
      kill "$pid" 2>/dev/null
      # The killed process exits non-zero; do not let set -e abort verification.
      wait "$pid" 2>/dev/null || true
    else
      echo -e "  ${RED}FAIL${NC} (process crashed within 5s)"
      ((gates_failed++))
    fi
  fi

  # ─── Gate 4: Safety ───
  echo ""
  echo "Gate 4: Safety"
  if [ "$safety_gate" = "false" ]; then
    echo -e "  ${YELLOW}SKIP${NC} (disabled in config)"
    ((gates_skipped++))
  else
    local safety_issues=0

    # Check for leaked secrets
    if grep -rn -E '(?i)(api[_-]?key|secret|password|token)\s*[:=]\s*['"'"'"][^'"'"'"]{8,}' \
      --include="*.ts" --include="*.js" --include="*.py" --include="*.java" \
      --include="*.go" --include="*.rs" --include="*.yaml" --include="*.json" \
      . 2>/dev/null | grep -v node_modules | grep -v ".forgeteam" | grep -v "package-lock" > /dev/null 2>&1; then
      echo -e "  ${RED}ISSUE${NC}: potential secrets detected in source"
      ((safety_issues++))
    fi

    # Check if .env is tracked by git
    if git ls-files --error-unmatch .env 2>/dev/null > /dev/null; then
      echo -e "  ${RED}ISSUE${NC}: .env is tracked by git"
      ((safety_issues++))
    fi

    if [ $safety_issues -eq 0 ]; then
      echo -e "  ${GREEN}PASS${NC}"
      ((gates_passed++))
      _analytics_event safety gate pass "no safety issues" || true
    else
      echo -e "  ${RED}FAIL${NC} ($safety_issues issue(s))"
      ((gates_failed++))
      _analytics_event safety gate fail "${safety_issues} safety issues" || true
    fi
  fi

  # ─── Summary ───
  echo ""
  echo "════════════════════════════════"
  echo "Results: ${gates_passed} passed, ${gates_failed} failed, ${gates_skipped} skipped"

  if [ $gates_failed -eq 0 ]; then
    echo -e "${GREEN}✓ All gates passed${NC}"
    return 0
  else
    echo -e "${RED}✗ Verification failed${NC}"
    return 1
  fi
}

forge_doctor() {
  echo -e "${BLUE}ForgeTeam Doctor${NC}"
  echo "════════════════════════════════"

  local checks_pass=0 checks_warn=0 checks_fail=0

  # ─── Check 1: config.yaml structure ───
  echo ""
  echo "Check 1: Configuration"

  if [ ! -f ".forgeteam/config.yaml" ]; then
    echo -e "  ${RED}✗${NC} .forgeteam/config.yaml not found"
    echo "    Fix: run 'forge init' to initialize project"
    ((checks_fail++))
  else
    local config_ok=true

    # Required top-level keys
    local required_keys=("project:" "routing:" "verification:" "commands:" "safety:")
    for key in "${required_keys[@]}"; do
      if ! grep -q "^${key}" .forgeteam/config.yaml 2>/dev/null; then
        echo -e "  ${RED}✗${NC} Missing section: ${key%:}"
        echo "    Fix: run 'forge init' to regenerate config"
        config_ok=false
        ((checks_fail++))
      fi
    done

    # Required project fields
    local project_fields=("name:" "language:" "type:")
    for field in "${project_fields[@]}"; do
      if ! grep -q "^  ${field}" .forgeteam/config.yaml 2>/dev/null; then
        echo -e "  ${YELLOW}⚠${NC}  Missing project.${field%:}"
        echo "    Fix: add '  ${field} <value>' under project: section"
        config_ok=false
        ((checks_warn++))
      fi
    done

    # Check language value is recognized
    local lang_val
    lang_val=$(grep "^  language:" .forgeteam/config.yaml 2>/dev/null | head -1 | sed 's/^[^:]*: *//' | tr -d '"')
    if [ -n "$lang_val" ] && [[ ! "$lang_val" =~ ^(typescript|java|go|rust|python|unknown)$ ]]; then
      echo -e "  ${YELLOW}⚠${NC}  Unrecognized language: $lang_val"
      echo "    Supported: typescript, java, go, rust, python"
      ((checks_warn++))
      config_ok=false
    fi

    if [ "$config_ok" = true ]; then
      echo -e "  ${GREEN}✓${NC} config.yaml is valid"
      ((checks_pass++))
    fi
  fi

  # ─── Check 2: Skills directory ───
  echo ""
  echo "Check 2: Skills"

  if [ ! -d "$FORGE_SKILLS" ]; then
    echo -e "  ${RED}✗${NC} Skills directory not found: $FORGE_SKILLS"
    echo "    Fix: run 'forge sync' to install skills"
    ((checks_fail++))
  else
    local skills_ok=true
    local core_skills=("plan" "execute" "verify" "ship" "debug" "review" "propose" "onboard" "memory" "evolve")
    local missing_skills=()

    for skill in "${core_skills[@]}"; do
      if [ ! -f "$FORGE_SKILLS/$skill/SKILL.md" ]; then
        missing_skills+=("$skill")
      fi
    done

    if [ ${#missing_skills[@]} -gt 0 ]; then
      echo -e "  ${RED}✗${NC} Missing skills: ${missing_skills[*]}"
      echo "    Fix: run 'forge sync' to restore missing skills"
      ((checks_fail++))
      skills_ok=false
    fi

    # Validate SKILL.md frontmatter
    local invalid_skills=()
    for skill_file in "$FORGE_SKILLS"/*/SKILL.md; do
      [ -f "$skill_file" ] || continue
      if ! head -1 "$skill_file" | grep -q "^---$"; then
        invalid_skills+=("$(basename "$(dirname "$skill_file")")")
      elif ! grep -q "^name:" "$skill_file"; then
        invalid_skills+=("$(basename "$(dirname "$skill_file")")")
      fi
    done

    if [ ${#invalid_skills[@]} -gt 0 ]; then
      echo -e "  ${YELLOW}⚠${NC}  Invalid frontmatter: ${invalid_skills[*]}"
      echo "    Fix: ensure SKILL.md starts with --- and contains name: field"
      ((checks_warn++))
      skills_ok=false
    fi

    # Check version.txt
    if [ ! -f "$FORGE_SKILLS/version.txt" ]; then
      echo -e "  ${YELLOW}⚠${NC}  Missing skills/version.txt"
      echo "    Fix: run 'forge sync' to restore"
      ((checks_warn++))
      skills_ok=false
    fi

    if [ "$skills_ok" = true ]; then
      local skill_count
      skill_count=$(find "$FORGE_SKILLS" -maxdepth 2 -name "SKILL.md" 2>/dev/null | wc -l | tr -d ' ')
      echo -e "  ${GREEN}✓${NC} $skill_count skills installed, all valid"
      ((checks_pass++))
    fi
  fi

  # ─── Check 3: Platform configuration ───
  echo ""
  echo "Check 3: Platform Config"

  if [ ! -f ".forgeteam/config.yaml" ]; then
    echo -e "  ${YELLOW}⚠${NC}  Skipped (no config.yaml)"
    ((checks_warn++))
  else
    local target
    target=$(grep "target:" .forgeteam/config.yaml 2>/dev/null | head -1 | sed 's/^[^:]*: *//' | tr -d '"')
    target="${target:-claude}"

    local platform_ok=true

    case "$target" in
      claude)
        if [ ! -f "CLAUDE.md" ]; then
          echo -e "  ${RED}✗${NC} CLAUDE.md not found (target: claude)"
          echo "    Fix: run 'forge generate --target claude'"
          ((checks_fail++))
          platform_ok=false
        fi
        if [ ! -d ".claude/commands" ]; then
          echo -e "  ${YELLOW}⚠${NC}  .claude/commands/ not found"
          echo "    Fix: run 'forge generate --target claude'"
          ((checks_warn++))
          platform_ok=false
        fi
        ;;
      cursor)
        if [ ! -f ".cursor/rules/forgeteam.mdc" ] && [ ! -d ".cursor/rules" ]; then
          echo -e "  ${RED}✗${NC} .cursor/rules/ not found (target: cursor)"
          echo "    Fix: run 'forge generate --target cursor'"
          ((checks_fail++))
          platform_ok=false
        fi
        ;;
      codex)
        if [ ! -f "codex.md" ]; then
          echo -e "  ${RED}✗${NC} codex.md not found (target: codex)"
          echo "    Fix: run 'forge generate --target codex'"
          ((checks_fail++))
          platform_ok=false
        fi
        ;;
      opencode)
        if [ ! -f "AGENTS.md" ]; then
          echo -e "  ${RED}✗${NC} AGENTS.md not found (target: opencode)"
          echo "    Fix: run 'forge generate --target opencode'"
          ((checks_fail++))
          platform_ok=false
        fi
        ;;
      windsurf)
        if [ ! -f ".windsurf/rules/forgeteam.md" ]; then
          echo -e "  ${RED}✗${NC} .windsurf/rules/forgeteam.md not found (target: windsurf)"
          echo "    Fix: run 'forge generate --target windsurf'"
          ((checks_fail++))
          platform_ok=false
        fi
        ;;
      *)
        echo -e "  ${YELLOW}⚠${NC}  Unknown target: $target"
        echo "    Valid targets: claude, cursor, codex, opencode, windsurf"
        ((checks_warn++))
        platform_ok=false
        ;;
    esac

    # Check adapter exists
    if [ ! -f "$FORGE_HOME/adapters/${target}.sh" ]; then
      echo -e "  ${RED}✗${NC} Adapter not found: adapters/${target}.sh"
      echo "    Fix: run 'forge sync' to restore adapters"
      ((checks_fail++))
      platform_ok=false
    fi

    if [ "$platform_ok" = true ]; then
      echo -e "  ${GREEN}✓${NC} Platform files consistent (target: $target)"
      ((checks_pass++))
    fi
  fi

  # ─── Check 4: Memory files ───
  echo ""
  echo "Check 4: Memory"

  if [ ! -d ".forgeteam/memory" ]; then
    echo -e "  ${YELLOW}⚠${NC}  .forgeteam/memory/ not found"
    echo "    Fix: run 'forge init' or 'forge onboard'"
    ((checks_warn++))
  else
    local memory_ok=true

    if [ ! -f ".forgeteam/memory/project-map.md" ]; then
      echo -e "  ${YELLOW}⚠${NC}  project-map.md missing"
      echo "    Fix: run 'forge onboard' to regenerate"
      ((checks_warn++))
      memory_ok=false
    else
      # Check if project-map is stale (older than 30 days)
      local map_age
      if [ "$(uname)" = "Darwin" ]; then
        map_age=$(( ( $(date +%s) - $(stat -f %m .forgeteam/memory/project-map.md) ) / 86400 ))
      else
        map_age=$(( ( $(date +%s) - $(stat -c %Y .forgeteam/memory/project-map.md) ) / 86400 ))
      fi
      if [ "$map_age" -gt 30 ]; then
        echo -e "  ${YELLOW}⚠${NC}  project-map.md is ${map_age} days old"
        echo "    Fix: run 'forge onboard' to refresh"
        ((checks_warn++))
        memory_ok=false
      fi
    fi

    if [ "$memory_ok" = true ]; then
      echo -e "  ${GREEN}✓${NC} Memory files present and fresh"
      ((checks_pass++))
    fi
  fi

  # ─── Check 5: Version compatibility ───
  echo ""
  echo "Check 5: Version"

  local local_version
  local_version=$(cat "$FORGE_SKILLS/version.txt" 2>/dev/null || echo "unknown")

  if [ "$local_version" = "unknown" ]; then
    echo -e "  ${YELLOW}⚠${NC}  Cannot determine local skill version"
    echo "    Fix: run 'forge sync'"
    ((checks_warn++))
  else
    echo -e "  ${GREEN}✓${NC} Skills version: v${local_version}"
    ((checks_pass++))

    # Check if upstream has newer version (non-blocking, best-effort)
    if [ -f "$FORGE_HOME/.upstream/skills/version.txt" ]; then
      local remote_version
      remote_version=$(cat "$FORGE_HOME/.upstream/skills/version.txt" 2>/dev/null || echo "")
      if [ -n "$remote_version" ] && [ "$remote_version" != "$local_version" ]; then
        echo -e "  ${YELLOW}⚠${NC}  Update available: v${remote_version}"
        echo "    Fix: run 'forge sync' to update"
        ((checks_warn++))
      fi
    fi
  fi

  # ─── Summary ───
  echo ""
  echo "════════════════════════════════"
  echo "Results: ${checks_pass} passed, ${checks_warn} warnings, ${checks_fail} errors"
  echo ""

  if [ $checks_fail -eq 0 ] && [ $checks_warn -eq 0 ]; then
    echo -e "${GREEN}✓ Everything looks good!${NC}"
    return 0
  elif [ $checks_fail -eq 0 ]; then
    echo -e "${YELLOW}⚠ Healthy with warnings. See suggestions above.${NC}"
    return 0
  else
    echo -e "${RED}✗ Issues found. Run suggested fixes above.${NC}"
    return 1
  fi
}

forge_evolve_cli() {
  local subcmd="${1:-report}"

  case "$subcmd" in
    report)     _evolve_report ;;
    --create-ep) shift; _evolve_create_ep "$@" ;;
    -h|--help)
      echo "Usage: forge evolve [command]"
      echo ""
      echo "Commands:"
      echo "  report          Generate evolution report from local signals (default)"
      echo "  --create-ep     Create EP from latest report findings"
      echo ""
      echo "The report collects:"
      echo "  • Skill usage patterns (from memory/state)"
      echo "  • Circuit breaker triggers (from safety.log)"
      echo "  • Config drift (from doctor output)"
      echo "  • Version status (local vs upstream)"
      echo "  • Pending EPs status"
      ;;
    *) echo "Unknown: $subcmd. Use 'forge evolve --help'"; return 1 ;;
  esac
}

_evolve_report() {
  echo -e "${BLUE}ForgeTeam Evolve — Signal Collection${NC}"
  echo "════════════════════════════════════════"
  echo ""

  local report_dir="evolution"
  mkdir -p "$report_dir"

  local today
  today=$(date '+%Y-%m-%d')
  local report_file="$report_dir/evolution-report-${today}.md"

  # ─── Signal 1: Version & Update Status ───
  echo "Collecting: version status..."
  local local_version="unknown"
  local remote_version="unknown"
  local update_available="false"

  local_version=$(cat "$FORGE_SKILLS/version.txt" 2>/dev/null || echo "unknown")
  if [ -f "$FORGE_HOME/.upstream/skills/version.txt" ]; then
    remote_version=$(cat "$FORGE_HOME/.upstream/skills/version.txt" 2>/dev/null || echo "unknown")
    [ "$remote_version" != "$local_version" ] && update_available="true"
  fi

  # ─── Signal 2: Skill Usage Patterns ───
  echo "Collecting: skill usage patterns..."

  # Count archived specs as completed workflows
  local completed_workflows=0
  if [ -d "specs/archived" ]; then
    completed_workflows=$(find specs/archived -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
  fi

  local analytics_events=0 analytics_completed=0 analytics_failed=0
  if [ -f ".forgeteam/analytics/events.jsonl" ]; then
    analytics_events=$(wc -l < .forgeteam/analytics/events.jsonl | tr -d ' ')
    analytics_completed=$(grep -c '"outcome":"pass"\|"outcome":"completed"' .forgeteam/analytics/events.jsonl 2>/dev/null || true)
    analytics_failed=$(grep -c '"outcome":"fail"\|"outcome":"failed"' .forgeteam/analytics/events.jsonl 2>/dev/null || true)
  fi

  local active_workflows=0
  if [ -d "specs/active" ]; then
    active_workflows=$(find specs/active -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
  fi

  # ─── Signal 3: Safety & Circuit Breaker ───
  echo "Collecting: safety signals..."
  local safety_triggers=0
  local circuit_breaks=0

  if [ -f ".forgeteam/safety.log" ]; then
    safety_triggers=$(wc -l < .forgeteam/safety.log 2>/dev/null | tr -d ' ')
  fi
  if [ -f ".forgeteam/gates.log" ]; then
    circuit_breaks=$(grep -c "CIRCUIT_BREAK\|FAIL" .forgeteam/gates.log 2>/dev/null || echo "0")
  fi

  # ─── Signal 4: Extension Usage ───
  echo "Collecting: extension status..."
  local installed_extensions=0
  if [ -d ".forgeteam/extensions/skills" ]; then
    installed_extensions=$(find .forgeteam/extensions/skills -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
  fi

  # ─── Signal 5: EP Status ───
  echo "Collecting: evolution proposals..."
  local ep_total=0 ep_draft=0 ep_accepted=0
  for f in evolution/EP-[0-9]*.md; do
    [ -f "$f" ] || continue
    echo "$f" | grep -q "template" && continue
    ep_total=$((ep_total + 1))
    grep -q "状态: draft" "$f" 2>/dev/null && ep_draft=$((ep_draft + 1))
    grep -q "状态: accepted" "$f" 2>/dev/null && ep_accepted=$((ep_accepted + 1))
  done

  # ─── Signal 6: Project Health ───
  echo "Collecting: project health..."
  local project_age_days=0
  if [ -f ".forgeteam/memory/project-map.md" ]; then
    if [ "$(uname)" = "Darwin" ]; then
      project_age_days=$(( ( $(date +%s) - $(stat -f %m .forgeteam/memory/project-map.md) ) / 86400 ))
    else
      project_age_days=$(( ( $(date +%s) - $(stat -c %Y .forgeteam/memory/project-map.md) ) / 86400 ))
    fi
  fi

  # ─── Generate Report ───
  echo ""
  echo "Generating report..."

  cat > "$report_file" <<EOF
# Evolution Report — ${today}

> Generated by: forge evolve
> ForgeTeam version: v${local_version}

---

## Local Signals

### Version Status
- Local version: v${local_version}
- Remote version: v${remote_version}
- Update available: ${update_available}

### Usage Patterns
- Completed workflows: ${completed_workflows}
- Active workflows: ${active_workflows}
- Project age: ${project_age_days} days
- Installed extensions: ${installed_extensions}
- Local analytics events: ${analytics_events}
- Successful / failed events: ${analytics_completed} / ${analytics_failed}

### Quality Signals
- Safety log entries: ${safety_triggers}
- Gate failures / circuit breaks: ${circuit_breaks}

### Evolution Proposals
- Total EPs: ${ep_total}
- Draft: ${ep_draft}
- Accepted: ${ep_accepted}

---

## Observations

EOF

  # Auto-generate observations based on signals
  {
    if [ "$update_available" = "true" ]; then
      echo "- **Update available**: v${local_version} → v${remote_version}. Run \`forge sync\` to update."
    fi

    if [ "$completed_workflows" -gt 5 ] && [ "$installed_extensions" -eq 0 ]; then
      echo "- **Extension opportunity**: ${completed_workflows} workflows completed but no extensions installed. Consider adding domain-specific extensions."
    fi

    if [ "$analytics_events" -eq 0 ]; then
      echo "- **Insufficient workflow data**: no local analytics events yet. After a task, record stage outcomes with \`forge analytics event <stage> <event> <pass|fail>\`; no code, prompt, or secret is recorded."
    fi

    if [ "$circuit_breaks" -gt 3 ]; then
      echo "- **Quality concern**: ${circuit_breaks} gate failures detected. Review verify configuration or skill constraints."
    fi

    if [ "$project_age_days" -gt 30 ] && [ "$completed_workflows" -eq 0 ]; then
      echo "- **Adoption stall**: Project initialized ${project_age_days} days ago but no completed workflows. Consider running \`forge onboard\` to refresh."
    fi

    if [ "$ep_draft" -gt 2 ]; then
      echo "- **EP backlog**: ${ep_draft} proposals still in draft. Consider reviewing and advancing."
    fi

    echo ""
    echo "---"
    echo ""
    echo "## Recommendations"
    echo ""
    echo "_Fill in after reviewing signals above. Use \`forge evolve --create-ep\` to turn a recommendation into a formal Evolution Proposal._"
    echo ""
    echo "---"
    echo ""
    echo "## Next Steps"
    echo ""
    echo "- [ ] Review observations above"
    echo "- [ ] Decide which signals warrant action"
    echo "- [ ] Create EP for significant changes: \`forge evolve --create-ep <title>\`"
    echo "- [ ] For deeper ecosystem analysis, use \`/forge-evolve\` in your AI tool"
  } >> "$report_file"

  echo ""
  echo -e "${GREEN}✓${NC} Report generated: $report_file"
  echo ""
  echo "Summary:"
  echo "  Version: v${local_version} (update: ${update_available})"
  echo "  Workflows: ${completed_workflows} completed, ${active_workflows} active"
  echo "  Safety: ${safety_triggers} log entries, ${circuit_breaks} failures"
  echo "  Extensions: ${installed_extensions} installed"
  echo "  EPs: ${ep_total} total (${ep_draft} draft, ${ep_accepted} accepted)"
  echo ""
  echo "Next: review the report and use 'forge evolve --create-ep <title>' for action items"
}

_evolve_create_ep() {
  local title="$*"
  if [ -z "$title" ]; then
    echo "Usage: forge evolve --create-ep <title>"
    echo "  Creates a new Evolution Proposal from report findings"
    return 1
  fi
  forge_ep create "$title"
}

forge_add() {
  local source="${1:-}"
  if [ -z "$source" ]; then
    echo "Usage: forge add <source>"
    echo ""
    echo "Sources:"
    echo "  <name>             Install from official registry"
    echo "  <git-url>          Install from Git repository"
    echo "  <local-path>       Install from local directory"
    echo ""
    echo "Options:"
    echo "  --list             List available extensions in registry"
    echo ""
    echo "Related:"
    echo "  forge remove <name>   Uninstall an extension"
    return 1
  fi

  case "$source" in
    --list) _add_list_registry ;;
    *)      _add_install "$source" ;;
  esac
}

forge_remove() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    echo "Usage: forge remove <name>"
    echo "  Removes an installed extension from .forgeteam/extensions/skills/"
    return 1
  fi

  # H1: Reject path traversal and invalid characters
  if echo "$name" | grep -qE '/|\.\.'; then
    echo -e "${RED}Error: invalid extension name '$name' (must not contain / or ..)${NC}"
    return 1
  fi

  local ext_dir=".forgeteam/extensions/skills/$name"
  if [ ! -d "$ext_dir" ]; then
    echo -e "${RED}Error: extension '$name' not installed${NC}"
    echo "  Installed extensions are in: .forgeteam/extensions/skills/"
    return 1
  fi

  rm -rf "$ext_dir"
  echo -e "${GREEN}✓${NC} Removed: $name"

  # H2: Use grep -F for exact match before sed deletion
  if [ -f ".forgeteam/config.yaml" ]; then
    if grep -Fq "\"${name}\"" .forgeteam/config.yaml 2>/dev/null; then
      if [ "$(uname)" = "Darwin" ]; then
        grep -Fv "\"${name}\"" .forgeteam/config.yaml > .forgeteam/config.yaml.tmp && mv .forgeteam/config.yaml.tmp .forgeteam/config.yaml
      else
        grep -Fv "\"${name}\"" .forgeteam/config.yaml > .forgeteam/config.yaml.tmp && mv .forgeteam/config.yaml.tmp .forgeteam/config.yaml
      fi
      echo "  Updated config.yaml"
    fi
  fi
}

_add_list_registry() {
  local registry_file="$FORGE_HOME/registry/official.yaml"
  if [ ! -f "$registry_file" ]; then
    echo "No official registry found."
    echo "Run 'forge sync' to update, or install by Git URL."
    return 1
  fi

  echo -e "${BLUE}Official Extensions${NC}"
  echo "────────────────────────────────────"
  printf "  %-24s %s\n" "Name" "Description"
  echo "  ──────────────────────── ──────────────────────────────"

  # Parse simple YAML format: "name: description"
  grep "^  [a-z]" "$registry_file" 2>/dev/null | while IFS=: read -r name desc; do
    name=$(echo "$name" | tr -d ' "')
    desc=$(echo "$desc" | sed 's/^ *//')
    printf "  %-24s %s\n" "$name" "$desc"
  done
}

_add_install() {
  local source="$1"

  if [ ! -d ".forgeteam" ]; then
    echo -e "${RED}Error: not a ForgeTeam project. Run 'forge init' first.${NC}"
    return 1
  fi

  mkdir -p .forgeteam/extensions/skills

  # Determine install method
  if echo "$source" | grep -qE '\.git$|^https?://|^git@'; then
    _add_from_git "$source"
  elif [ -d "$source" ]; then
    _add_from_local "$source"
  else
    _add_from_registry "$source"
  fi
}

_add_from_git() {
  local url="$1"
  local tmp_dir
  tmp_dir=$(mktemp -d)

  echo "Cloning from: $url"
  if ! git clone --depth 1 "$url" "$tmp_dir/repo" 2>/dev/null; then
    rm -rf "$tmp_dir"
    echo -e "${RED}Error: failed to clone $url${NC}"
    return 1
  fi

  # Find SKILL.md in cloned repo
  local skill_file
  skill_file=$(find "$tmp_dir/repo" -maxdepth 2 -name "SKILL.md" | head -1)

  if [ -z "$skill_file" ]; then
    rm -rf "$tmp_dir"
    echo -e "${RED}Error: no SKILL.md found in repository${NC}"
    return 1
  fi

  local skill_dir
  skill_dir=$(dirname "$skill_file")
  local skill_name
  skill_name=$(grep "^name:" "$skill_file" 2>/dev/null | head -1 | sed 's/^name: *//' | tr -d '"')
  [ -z "$skill_name" ] && skill_name=$(basename "$skill_dir")

  local target=".forgeteam/extensions/skills/$skill_name"
  if [ -d "$target" ]; then
    echo -e "${YELLOW}Warning: '$skill_name' already installed, overwriting${NC}"
    rm -rf "$target"
  fi

  cp -r "$skill_dir" "$target"
  rm -rf "$tmp_dir"

  _add_register "$skill_name"
  echo -e "${GREEN}✓${NC} Installed: $skill_name (from git)"
}

_add_from_local() {
  local path="$1"

  if [ ! -f "$path/SKILL.md" ]; then
    echo -e "${RED}Error: no SKILL.md found in $path${NC}"
    return 1
  fi

  local skill_name
  skill_name=$(grep "^name:" "$path/SKILL.md" 2>/dev/null | head -1 | sed 's/^name: *//' | tr -d '"')
  [ -z "$skill_name" ] && skill_name=$(basename "$path")

  local target=".forgeteam/extensions/skills/$skill_name"
  if [ -d "$target" ]; then
    echo -e "${YELLOW}Warning: '$skill_name' already installed, overwriting${NC}"
    rm -rf "$target"
  fi

  cp -r "$path" "$target"
  _add_register "$skill_name"
  echo -e "${GREEN}✓${NC} Installed: $skill_name (from local)"
}

_add_from_registry() {
  local name="$1"
  local registry_file="$FORGE_HOME/registry/official.yaml"

  # Check built-in extensions first
  local builtin_path="$FORGE_HOME/extensions"
  local found_path=""

  # Search in category/name pattern
  for category_dir in "$builtin_path"/*/; do
    [ -d "$category_dir" ] || continue
    if [ -d "${category_dir}${name}" ] && [ -f "${category_dir}${name}/SKILL.md" ]; then
      found_path="${category_dir}${name}"
      break
    fi
  done

  # Also try flat name match
  if [ -z "$found_path" ] && [ -d "$builtin_path/$name" ] && [ -f "$builtin_path/$name/SKILL.md" ]; then
    found_path="$builtin_path/$name"
  fi

  if [ -n "$found_path" ]; then
    _add_from_local "$found_path"
    return 0
  fi

  # Try registry file
  if [ -f "$registry_file" ]; then
    local url
    url=$(grep "^  ${name}:" "$registry_file" 2>/dev/null | head -1 | sed 's/^[^:]*: *//' | grep -oE 'https?://[^ ]+')
    if [ -n "$url" ]; then
      _add_from_git "$url"
      return 0
    fi
  fi

  echo -e "${RED}Error: extension '$name' not found${NC}"
  echo ""
  echo "Try:"
  echo "  forge add --list            # see available extensions"
  echo "  forge add <git-url>         # install from Git"
  echo "  forge add <local-path>      # install from local directory"
  return 1
}

_add_register() {
  local name="$1"
  if [ -f ".forgeteam/config.yaml" ]; then
    # Check if already registered
    if grep -q "\"${name}\"" .forgeteam/config.yaml 2>/dev/null; then
      return 0
    fi
    # Add to extensions.skills list
    if grep -q "^  skills:" .forgeteam/config.yaml 2>/dev/null; then
      if [ "$(uname)" = "Darwin" ]; then
        sed -i '' "/^  skills:/a\\
    - \"${name}\"" .forgeteam/config.yaml
      else
        sed -i "/^  skills:/a\\    - \"${name}\"" .forgeteam/config.yaml
      fi
    fi
  fi
}

forge_ep() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    create) _ep_create "$@" ;;
    list)   _ep_list ;;
    status) _ep_status "$@" ;;
    *)
      echo "Usage: forge ep <command>"
      echo ""
      echo "Commands:"
      echo "  create <title>    Create a new Evolution Proposal"
      echo "  list              List all proposals with status"
      echo "  status <NNN> <s>  Update status (draft/reviewing/accepted/rejected/implemented)"
      ;;
  esac
}

_ep_next_number() {
  local max=0
  for f in evolution/EP-[0-9]*.md; do
    [ -f "$f" ] || continue
    # Skip template file
    echo "$f" | grep -q "template" && continue
    local num
    num=$(basename "$f" | sed 's/EP-0*\([0-9]*\)-.*/\1/')
    [ "$num" -gt "$max" ] 2>/dev/null && max="$num"
  done
  printf "%03d" $((max + 1))
}

_ep_create() {
  local title="$*"
  if [ -z "$title" ]; then
    echo -e "${RED}Error: title required${NC}"
    echo "Usage: forge ep create <title>"
    return 1
  fi

  mkdir -p evolution

  local number
  number=$(_ep_next_number)
  local slug
  slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-' | cut -c1-50)
  local filename="evolution/EP-${number}-${slug}.md"
  local today
  today=$(date '+%Y-%m-%d')

  cat > "$filename" <<EOF
# EP-${number}: ${title}

> 状态: draft
> 创建: ${today}
> 作者: $(git config user.name 2>/dev/null || echo "unknown")

---

## 触发信号

什么外部变化触发了这个进化提案？

- 观察到的技术趋势：
- 来源（不限于特定项目，可以是论文、社区讨论、行业报告、用户反馈）：
- 时效性判断（是短期热点还是长期趋势）：

## 当前短板

ForgeTeam 在这个方向上缺什么？

- 现有能力：
- 缺失的能力：
- 用户痛点/反馈：

## 融合方案

### 方案描述

怎么做？具体改什么？

### 落位

| 变更 | 位置 | 类型 |
|------|------|------|
| | | core / extension / adapter / template |

### 实现路径

分几步完成？每步交付什么？

## 验证标准

怎么证明这次进化是成功的？

- [ ]
- [ ] 不违反进化红线（纯文本 / 一人可用 / 3分钟上手 / 离线 / 平台无关 / 人类决策）

## 兼容影响

- 是否 breaking change：
- 影响的现有 skill：
- 迁移方案（如需）：

