forge_sync() {
  local upstream_repo="https://github.com/chengxuninu/ForgeTeam.git"

  echo -e "${BLUE}Syncing from upstream...${NC}"

  if [ -d "$FORGE_HOME/.upstream" ]; then
    echo "Pulling latest..."
    git -C "$FORGE_HOME/.upstream" pull --ff-only 2>/dev/null || true
  else
    echo "Cloning upstream..."
    git clone --depth 1 "$upstream_repo" "$FORGE_HOME/.upstream"
  fi

  local remote_version local_version
  remote_version=$(cat "$FORGE_HOME/.upstream/skills/version.txt" 2>/dev/null || echo "0.0.0")
  local_version=$(cat "$FORGE_SKILLS/version.txt" 2>/dev/null || echo "0.0.0")

  echo "Local: v${local_version}"
  echo "Remote: v${remote_version}"

  if [ "$local_version" = "$remote_version" ]; then
    echo -e "${GREEN}Already up to date.${NC}"
    return 0
  fi

  echo "Updating skills..."
  for skill_dir in "$FORGE_HOME/.upstream/skills"/*/; do
    local skill_name
    skill_name=$(basename "$skill_dir")
    local target_dir="$FORGE_SKILLS/$skill_name"

    if [ -d "$target_dir" ] && [ -f "$target_dir/.local-modified" ]; then
      echo -e "  ${YELLOW}SKIP${NC} $skill_name (locally modified)"
      continue
    fi

    echo -e "  ${GREEN}UPDATE${NC} $skill_name"
    cp -r "$skill_dir" "$target_dir"
  done

  echo "$remote_version" > "$FORGE_SKILLS/version.txt"

  if [ -f ".forgeteam/config.yaml" ]; then
    echo ""
    echo "Regenerating platform files..."
    local target
    target=$(grep "target:" .forgeteam/config.yaml | awk '{print $2}' | tr -d '"')
    forge_generate --target "${target:-claude}"
  fi

  echo ""
  echo -e "${GREEN}✓ Synced to v${remote_version}${NC}"
}

forge_status() {
  echo -e "${BLUE}ForgeTeam Status${NC}"
  echo "────────────────────────"

  if [ -f ".forgeteam/config.yaml" ]; then
    local name lang
    name=$(grep "name:" .forgeteam/config.yaml | head -1 | awk '{print $2}' | tr -d '"')
    lang=$(grep "language:" .forgeteam/config.yaml | awk '{print $2}' | tr -d '"')
    echo "Project: $name ($lang)"
  else
    echo -e "${YELLOW}Not initialized. Run: forge init${NC}"
    return 1
  fi

  echo ""

  if [ -f ".forgeteam/memory/state.md" ]; then
    echo "Current State:"
    grep "^- " .forgeteam/memory/state.md 2>/dev/null | head -6 | while read -r line; do
      echo "  $line"
    done
  else
    echo "State: idle (no active task)"
  fi

  echo ""

  if [ -d "specs/active" ]; then
    local active_count
    active_count=$(ls specs/active/ 2>/dev/null | wc -l | tr -d ' ')
    echo "Active Specs: $active_count"
    ls specs/active/ 2>/dev/null | while read -r spec; do
      local tasks_total tasks_done
      tasks_total=$(grep -c "^\- \[" "specs/active/$spec/tasks.md" 2>/dev/null || echo "0")
      tasks_done=$(grep -c "^\- \[x\]" "specs/active/$spec/tasks.md" 2>/dev/null || echo "0")
      echo "  • $spec ($tasks_done/$tasks_total)"
    done
  fi

  echo ""

  if [ -d "specs/archived" ]; then
    local archived_count
    archived_count=$(ls specs/archived/ 2>/dev/null | wc -l | tr -d ' ')
    echo "Archived Specs: $archived_count"
  fi
}

forge_config() {
  if [ -f ".forgeteam/config.yaml" ]; then
    cat .forgeteam/config.yaml
  else
    echo -e "${YELLOW}Not initialized. Run: forge init${NC}"
    exit 1
  fi
}

forge_skill() {
  local skill_name=$1
  echo -e "${BLUE}ForgeTeam: ${skill_name}${NC}"
  echo ""
  echo "This skill is designed to be executed by AI coding assistants."
  echo ""
  echo "Usage options:"
  echo "  • In Claude Code: use /forge-${skill_name}"
  echo "  • In Cursor: AI will auto-detect based on context"
  echo "  • Manual: read skills/${skill_name}/SKILL.md for instructions"
  echo ""
  echo "Skill file: \$HOME/.forgeteam/skills/${skill_name}/SKILL.md"
}

case "${1:-}" in
  init)       shift; forge_init "$@" ;;
  onboard)    shift; forge_onboard "$@" ;;
  generate)   shift; forge_generate "$@" ;;
  sync)       shift; forge_sync "$@" ;;
  status)     shift; forge_status "$@" ;;
  config)     shift; forge_config "$@" ;;
  version)    echo "ForgeTeam v${FORGE_VERSION}" ;;
  propose|html-prototype|plan|execute|review|verify|ship|debug|checkpoint|learn|evolve|safety-guard|quality-gate)
              forge_skill "$@" ;;
  -h|--help)  usage ;;
  "")         usage ;;
  *)          usage; exit 1 ;;
esac
