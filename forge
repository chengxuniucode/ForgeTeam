#!/bin/bash
# ForgeTeam CLI — 主入口
# 用法: forge <command> [options]

set -euo pipefail

FORGE_VERSION="1.0.0"
FORGE_HOME="${FORGE_HOME:-$HOME/.forgeteam}"
FORGE_SKILLS="$FORGE_HOME/skills"

# Color support (disabled when not a terminal)
if [ -t 1 ]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  BLUE='\033[0;34m'
  NC='\033[0m'
else
  RED='' GREEN='' YELLOW='' BLUE='' NC=''
fi

# Sanitize a string for safe YAML/markdown interpolation
sanitize_value() {
  local val="$1"
  # Remove characters that could break YAML or inject content
  val="${val//\"/}"
  val="${val//\`/}"
  val="${val//\$/}"
  val="${val//\\/}"
  # Limit length
  val="${val:0:128}"
  echo "$val"
}

# Portable date (macOS + Linux compatible)
portable_date() {
  date '+%Y-%m-%dT%H:%M:%S%z' 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S'
}

usage() {
  cat <<EOF
ForgeTeam v${FORGE_VERSION} — One person, full team delivery.

Usage: forge <command> [options]

Commands:
  init          Initialize ForgeTeam in current project
  onboard       Scan project and generate project map
  generate      Generate platform-specific files
  sync          Sync upstream skill updates
  status        Show current task status
  config        View/edit configuration
  version       Show version

Skill Commands (also available as slash commands in AI tools):
  propose         Start a new proposal (full route)
  html-prototype  Generate HTML prototype for visual confirmation
  plan            Create task plan
  execute         Execute tasks
  review          Run code review
  verify          Run verification gates
  ship            Commit and archive
  debug           Debug verification failures
  checkpoint      Save current progress
  learn           Extract learnings to memory
  evolve          Evaluate ecosystem changes
  safety-guard    Safety checks before dangerous operations
  quality-gate    Quality gate enforcement

Options:
  -h, --help    Show this help

EOF
}

# ─── Shared Detection Logic ───

detect_project() {
  # Outputs variables: lang, framework, type, build_cmd, test_cmd, start_cmd, dev_cmd, pkg_manager, project_name, project_version
  lang="unknown"
  framework=""
  type="web-app"
  build_cmd=""
  test_cmd=""
  start_cmd=""
  dev_cmd=""
  pkg_manager="unknown"
  project_name=$(sanitize_value "$(basename "$(pwd)")")
  project_version=""

  if [ -f "package.json" ]; then
    lang="typescript"
    build_cmd="npm run build"
    test_cmd="npm test"
    start_cmd="npm start"
    dev_cmd="npm run dev"

    # Detect package manager
    if [ -f "pnpm-lock.yaml" ]; then pkg_manager="pnpm"
    elif [ -f "yarn.lock" ]; then pkg_manager="yarn"
    elif [ -f "package-lock.json" ]; then pkg_manager="npm"
    else pkg_manager="npm"
    fi

    # Extract name/version safely
    local raw_name raw_version
    raw_name=$(grep '"name"' package.json 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/' || echo "")
    raw_version=$(grep '"version"' package.json 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/' || echo "")
    [ -n "$raw_name" ] && project_name=$(sanitize_value "$raw_name")
    [ -n "$raw_version" ] && project_version=$(sanitize_value "$raw_version")

    # Detect framework from dependencies
    if grep -q '"next"' package.json 2>/dev/null; then framework="next"
    elif grep -q '"react"' package.json 2>/dev/null; then framework="react"
    elif grep -q '"vue"' package.json 2>/dev/null; then framework="vue"
    elif grep -q '"express"' package.json 2>/dev/null; then framework="express"
    fi

    # Library detection
    if grep -q '"main"' package.json 2>/dev/null && [ "$framework" != "next" ]; then
      type="library"
    fi
  elif [ -f "pom.xml" ]; then
    lang="java"
    framework="spring"
    build_cmd="mvn compile"
    test_cmd="mvn test"
    start_cmd="mvn spring-boot:run"
  elif [ -f "build.gradle" ] || [ -f "build.gradle.kts" ]; then
    lang="java"
    framework="spring"
    build_cmd="./gradlew build"
    test_cmd="./gradlew test"
    start_cmd="./gradlew bootRun"
  elif [ -f "go.mod" ]; then
    lang="go"
    build_cmd="go build ./..."
    test_cmd="go test ./..."
    start_cmd="go run ."
  elif [ -f "Cargo.toml" ]; then
    lang="rust"
    build_cmd="cargo build"
    test_cmd="cargo test"
    start_cmd="cargo run"
  elif [ -f "pyproject.toml" ] || [ -f "requirements.txt" ]; then
    lang="python"
    test_cmd="pytest"
    if [ -f "manage.py" ]; then
      framework="django"
      start_cmd="python manage.py runserver"
    elif [ -f "requirements.txt" ] && grep -qi "fastapi" requirements.txt 2>/dev/null; then
      framework="fastapi"
      start_cmd="uvicorn main:app"
    elif [ -f "pyproject.toml" ] && grep -q '"fastapi"' pyproject.toml 2>/dev/null; then
      framework="fastapi"
      start_cmd="uvicorn main:app"
    fi
  fi
}

# ─── Commands ───

forge_init() {
  local project_dir
  project_dir=$(pwd)

  echo -e "${BLUE}ForgeTeam Init${NC}"
  echo "Project: $project_dir"
  echo ""

  if [ -d ".forgeteam" ]; then
    echo -e "${YELLOW}Warning: .forgeteam already exists${NC}"
    read -p "Reinitialize? [y/N] " confirm
    [ "$confirm" != "y" ] && exit 0
  fi

  echo "Creating .forgeteam/..."
  mkdir -p .forgeteam/memory
  mkdir -p .forgeteam/extensions/skills
  mkdir -p .forgeteam/extensions/templates
  mkdir -p specs/active
  mkdir -p specs/archived

  echo "Detecting project..."
  detect_project

  echo "Generating config.yaml..."
  cat > .forgeteam/config.yaml <<YAML
version: "1.0"

project:
  name: "${project_name}"
  type: "${type}"
  language: "${lang}"
  framework: "${framework}"
  description: ""

routing:
  micro_threshold: 50
  standard_threshold: 500
  default_route: "auto"
  force_full_on:
    - "database migration"
    - "new api endpoint"
    - "architecture change"

verification:
  build_gate: true
  test_gate: true
  run_gate: $([ "$type" = "library" ] && echo "false" || echo "true")
  safety_gate: true
  coverage_threshold: 80
  circuit_breaker_limit: 3
  test_gate_mode: "warn"

commands:
  build: "${build_cmd}"
  test: "${test_cmd}"
  start: "${start_cmd}"
  dev: "${dev_cmd}"
  lint: ""
  format: ""
  health_url: ""

memory:
  auto_update: true
  track_decisions: true
  track_issues: true
  max_known_issues: 50
  max_decisions: 100

safety:
  level: "standard"
  allow_force_push: false
  secret_scan: true
  protected_branches:
    - "main"
    - "master"

review:
  strict_mode: false
  security_check: true
  performance_check: true
  style_check: true
  max_review_rounds: 3

quality_gates:
  strict: false
  allow_skip: true
  skip_log: true

extensions:
  skills: []
  mcp_servers: []
  templates: []

adapters:
  target: "claude"
  auto_generate: true

upstream:
  repo: "https://github.com/chengxuninu/ForgeTeam.git"
  branch: "main"
  auto_check: false
  check_interval: "weekly"
  preserve_local: true
YAML

  # Update .gitignore
  if [ -f ".gitignore" ]; then
    if ! grep -Fq ".forgeteam/safety.log" .gitignore 2>/dev/null; then
      echo "" >> .gitignore
      echo "# ForgeTeam" >> .gitignore
      echo ".forgeteam/safety.log" >> .gitignore
      echo ".forgeteam/gates.log" >> .gitignore
    fi
  else
    cat > .gitignore <<'GITIGNORE'
# ForgeTeam
.forgeteam/safety.log
.forgeteam/gates.log
GITIGNORE
  fi

  echo ""
  echo "Running onboard..."
  forge_onboard

  echo ""
  echo "Generating platform files..."
  forge_generate --target "claude"

  echo ""
  echo -e "${GREEN}✓ ForgeTeam initialized successfully!${NC}"
  echo ""
  echo "Next steps:"
  echo "  1. Review .forgeteam/config.yaml"
  echo "  2. Review .forgeteam/memory/project-map.md"
  echo "  3. Start working: describe what you want to build"
}

forge_onboard() {
  echo -e "${BLUE}Onboard: Scanning project...${NC}"

  detect_project

  # Framework display name
  local framework_display="$framework"
  case "$framework" in
    next) framework_display="Next.js" ;;
    react) framework_display="React" ;;
    vue) framework_display="Vue" ;;
    express) framework_display="Express" ;;
    spring) framework_display="Spring Boot" ;;
    django) framework_display="Django" ;;
    fastapi) framework_display="FastAPI" ;;
  esac

  local tree_output
  tree_output=$(find . -maxdepth 2 -type d \
    ! -path "*/node_modules*" \
    ! -path "*/.git*" \
    ! -path "*/dist*" \
    ! -path "*/build*" \
    ! -path "*/target*" \
    ! -path "*/__pycache__*" \
    ! -path "*/vendor*" \
    ! -path "*/.forgeteam*" \
    2>/dev/null | sort | head -40)

  # Detect entry point
  local entry="unknown"
  if [ -f "src/index.ts" ]; then entry="src/index.ts"
  elif [ -f "src/main.ts" ]; then entry="src/main.ts"
  elif [ -f "src/index.js" ]; then entry="src/index.js"
  elif [ -f "index.js" ]; then entry="index.js"
  elif [ -f "src/main/java" ]; then entry="src/main/java/"
  elif [ -f "main.go" ]; then entry="main.go"
  elif [ -f "src/main.rs" ]; then entry="src/main.rs"
  elif [ -f "manage.py" ]; then entry="manage.py"
  fi

  # Detect test directory
  local test_dir="none detected"
  if [ -d "tests" ]; then test_dir="tests/"
  elif [ -d "test" ]; then test_dir="test/"
  elif [ -d "__tests__" ]; then test_dir="__tests__/"
  elif [ -d "src/test" ]; then test_dir="src/test/"
  fi

  # Detect config files
  local config_files
  config_files=$(find . -maxdepth 1 -name "*.config.*" -o -name ".env.example" -o -name "tsconfig.json" -o -name "application.yml" -o -name "application.properties" 2>/dev/null | sed 's|^\./||' | tr '\n' ', ' | sed 's/,$//')
  [ -z "$config_files" ] && config_files="none detected"

  mkdir -p .forgeteam/memory

  cat > .forgeteam/memory/project-map.md <<EOF
# Project Map

## 基础信息
- 名称: ${project_name}
- 类型: ${type}
- 语言: ${lang}
- 框架: ${framework_display}
- 版本: ${project_version}

## 构建与运行
- 包管理: ${pkg_manager}
- 构建命令: ${build_cmd}
- 测试命令: ${test_cmd}
- 启动命令: ${start_cmd}
- 开发命令: ${dev_cmd}

## 目录结构
${tree_output}

## 关键文件
- 入口: ${entry}
- 配置: ${config_files}
- 测试: ${test_dir}

## 备注
- 生成时间: $(portable_date)
- 最后更新: $(portable_date)
EOF

  echo -e "  ${GREEN}✓${NC} project-map.md generated"
}

forge_generate() {
  local target="claude"

  while [[ $# -gt 0 ]]; do
    case $1 in
      --target) target="$2"; shift 2 ;;
      *) echo "Unknown option: $1. Valid targets: claude, cursor, codex, opencode"; exit 1 ;;
    esac
  done

  echo -e "${BLUE}Generating for: ${target}${NC}"

  case "$target" in
    claude)   generate_claude ;;
    cursor)   generate_cursor ;;
    codex)    generate_codex ;;
    opencode) generate_opencode ;;
    *) echo "Unknown target: $target. Valid: claude, cursor, codex, opencode"; exit 1 ;;
  esac

  echo -e "${GREEN}✓ Generated ${target} configuration${NC}"
}

generate_claude() {
  mkdir -p .claude/commands

  # Backup existing CLAUDE.md if user has customized it
  if [ -f "CLAUDE.md" ]; then
    if ! grep -Fq "This project uses ForgeTeam" CLAUDE.md 2>/dev/null; then
      cp CLAUDE.md "CLAUDE.md.backup.$(date '+%Y%m%d%H%M%S')"
      echo -e "  ${YELLOW}NOTE${NC}: Existing CLAUDE.md backed up (had custom content)"
    fi
  fi

  cat > CLAUDE.md <<'CLAUDEEOF'
# ForgeTeam

This project uses ForgeTeam for AI-assisted development.

## Auto-Loaded Context

On session start, read:
- .forgeteam/memory/project-map.md
- .forgeteam/memory/state.md
- .forgeteam/memory/preferences.md
- .forgeteam/config.yaml

## Available Commands

- /forge-propose — Start a new feature proposal
- /forge-html-prototype — Generate HTML prototype for visual confirmation
- /forge-plan — Create execution plan
- /forge-execute — Run task execution
- /forge-review — Code review
- /forge-verify — Quality verification
- /forge-ship — Commit and archive
- /forge-debug — Fix verification failures
- /forge-checkpoint — Save progress
- /forge-learn — Extract learnings to memory
- /forge-evolve — Evaluate ecosystem changes and evolution
- /forge-safety-guard — Safety checks for dangerous operations
- /forge-quality-gate — Quality gate enforcement

## Workflow Rules

1. Auto-detect route level (micro/standard/full) based on change scope
2. Follow skill instructions exactly
3. Update state.md after each significant action
4. Never skip verification gates
5. Pause and ask human after 3 failed fix attempts
6. Keep documentation in sync with code changes

## Route Detection

- Micro (< 50 lines, <= 3 files, no API/DB change): execute → verify → done
- Standard (50-500 lines, <= 10 files): plan → [html] → execute → review → verify → ship
- Full (> 500 lines, multi-module): propose → [html] → plan → execute → review → verify → ship

Note: [html] = auto-insert html-prototype step when UI/page changes are involved

CLAUDEEOF

  for skill in propose html-prototype plan execute review verify ship debug checkpoint learn evolve safety-guard quality-gate; do
    cat > ".claude/commands/forge-${skill}.md" <<EOF
# forge ${skill}

Execute the ForgeTeam ${skill} skill.

Read and follow the instructions in the ForgeTeam ${skill} skill file at:
\`\$HOME/.forgeteam/skills/${skill}/SKILL.md\`

Context to load before execution:
- .forgeteam/config.yaml
- .forgeteam/memory/state.md
- .forgeteam/memory/project-map.md
- .forgeteam/memory/preferences.md
- specs/active/ (if exists)
EOF
  done
}

